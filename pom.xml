<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>
    <parent>
        <groupId>org.springframework.boot</groupId>
        <artifactId>spring-boot-starter-parent</artifactId>
        <version>3.2.6</version>
        <relativePath/>
    </parent>
    <groupId>com.example</groupId>
    <artifactId>virtual-clothing-store</artifactId>
    <version>0.0.1-SNAPSHOT</version>
    <name>virtual-clothing-store</name>
    <description>Virtual Clothing Store REST API</description>
    <packaging>pom</packaging>

    <modules>
        <module>discovery-server</module>
        <module>config-server</module>
        <module>api-gateway</module>
        <module>catalog-service</module>
        <module>order-service</module>
    </modules>
    <properties>
        <java.version>21</java.version>
        <spring-cloud.version>2023.0.5</spring-cloud.version>
        <!-- bump Spring Framework separately to satisfy Gateway's headerSet dependency -->
        <spring-framework.version>6.1.15</spring-framework.version>

        <!-- Sonar properties (must be in POM; sonar-project.properties is ignored by mvn sonar:sonar) -->
        <sonar.projectKey>DiasMurilo_virtual-clothing-store</sonar.projectKey>
        <sonar.organization>diasmurilo</sonar.organization>
        <sonar.host.url>https://sonarcloud.io</sonar.host.url>
        <sonar.java.source>21</sonar.java.source>
        <sonar.java.target>21</sonar.java.target>
        <sonar.sourceEncoding>UTF-8</sonar.sourceEncoding>

        <!-- JaCoCo: pick up both per-module and aggregate XML reports -->
        <sonar.coverage.jacoco.xmlReportPaths>
            ${project.basedir}/target/site/jacoco/jacoco.xml,
            ${project.basedir}/target/site/jacoco-aggregate/jacoco.xml
        </sonar.coverage.jacoco.xmlReportPaths>

        <!-- Coverage exclusions: skip boilerplate that can't realistically
             be unit-tested (DTOs, JPA entities, Spring Application stubs) -->
        <sonar.coverage.exclusions>
            **/dto/**,**/entity/**,
            **/service/CatalogClient*.java,
            **/*Application.java
        </sonar.coverage.exclusions>

        <!-- CPD exclusions: these files are intentionally near-identical
             across modules (getter/setter boilerplate, JPA mapping, Spring
             ControllerAdvice pattern).  Tell Sonar to skip them for duplication. -->
        <sonar.cpd.exclusions>
            **/dto/**,
            **/entity/**,
            **/exception/**,
            **/repository/**,
            **/*Application.java
        </sonar.cpd.exclusions>

        <!-- Do not scan build output or third-party resources -->
        <sonar.exclusions>**/target/**,**/node_modules/**</sonar.exclusions>

        <!-- Do not block the build waiting for the Quality Gate result.
             Analysis is still uploaded and visible in the SonarCloud dashboard. -->
        <sonar.qualitygate.wait>false</sonar.qualitygate.wait>
        <sonar.qualitygate.timeout>300</sonar.qualitygate.timeout>
    </properties>

    <dependencyManagement>
        <dependencies>
            <dependency>
                <groupId>org.springframework.cloud</groupId>
                <artifactId>spring-cloud-dependencies</artifactId>
                <version>${spring-cloud.version}</version>
                <type>pom</type>
                <scope>import</scope>
            </dependency>
        </dependencies>
    </dependencyManagement>

    <build>
        <plugins>
            <plugin>
                <groupId>org.springframework.boot</groupId>
                <artifactId>spring-boot-maven-plugin</artifactId>
            </plugin>
            <!-- JVM args for Surefire: @{argLine} is late-bound so JaCoCo's agent is included when prepare-agent runs first. -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-surefire-plugin</artifactId>
                <configuration>
                    <argLine>@{argLine} -Dnet.bytebuddy.experimental=true</argLine>
                </configuration>
            </plugin>
            <!-- JaCoCo plugin at parent level to allow aggregate reports across modules -->
            <plugin>
                <groupId>org.jacoco</groupId>
                <artifactId>jacoco-maven-plugin</artifactId>
                <version>0.8.12</version>
                <executions>
                    <execution>
                        <id>prepare-agent</id>
                        <goals>
                            <goal>prepare-agent</goal>
                        </goals>
                    </execution>
                    <!-- per-module HTML+XML report at verify phase -->
                    <execution>
                        <id>report</id>
                        <phase>verify</phase>
                        <goals>
                            <goal>report</goal>
                        </goals>
                    </execution>
                    <execution>
                        <id>report-aggregate</id>
                        <phase>verify</phase>
                        <goals>
                            <goal>report-aggregate</goal>
                        </goals>
                        <configuration>
                            <!-- aggregate across modules when run from parent -->
                            <aggregate>true</aggregate>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>
</project>